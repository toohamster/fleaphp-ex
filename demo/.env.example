# FLEA PHP Demo Environment Configuration
# Copy this file to .env and configure for your environment

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://127.0.0.1:8081

# Environment-specific files:
# - .env             (base config, always loaded)
# - .env.{APP_ENV}   (optional, loaded after base, overrides values)
# Example: APP_ENV=production loads .env then .env.production

# Database
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=blog
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Cache
CACHE_DRIVER=file

# Log
LOG_LEVEL=debug

# JWT (if using API)
JWT_SECRET=change-me-to-a-secure-secret-key
JWT_TTL=7200
