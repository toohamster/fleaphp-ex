{
    "name": "fleaphp/framework",
    "description": "FLEA - Lightweight PHP MVC Framework with PSR compliance, RESTful routing, middleware pipeline, JWT authentication, and RBAC support",
    "type": "library",
    "bin": ["bin/flea-cli"],
    "keywords": [
        "framework",
        "mvc",
        "psr-11",
        "psr-16",
        "psr-3",
        "router",
        "middleware",
        "jwt",
        "restful",
        "orm",
        "rbac",
        "lightweight",
        "php"
    ],
    "support": {
        "issues": "https://github.com/toohamster/fleaphp-ex/issues",
        "source": "https://github.com/toohamster/fleaphp-ex",
        "docs": "https://github.com/toohamster/fleaphp-ex/blob/master/SPEC.md"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "toohamster",
            "homepage": "https://github.com/toohamster/fleaphp-ex/"
        }
    ],
    "require": {
        "php": ">=7.4",
        "psr/log": "^1.0",
        "psr/container": "^2.0",
        "psr/simple-cache": "^1.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "FLEA\\": "src/FLEA/"
        },
        "files": [
            "src/Functions.php",
            "src/FLEA.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "FLEA\\Tests\\": "tests/"
        }
    }
}
