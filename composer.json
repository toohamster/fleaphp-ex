{
    "name": "toohamster/fleaphp-ex",
    "description": "A lightweight PHP framework with MVC architecture, database abstraction layer, and RBAC support",
    "type": "library",
    "keywords": [
        "framework",
        "mvc",
        "database",
        "orm",
        "rbac",
        "php"
    ],
    "license": "LGPL-2.1-or-later",
    "authors": [
        {
            "name": "toohamster",
            "homepage": "https://github.com/toohamster/fleaphp-ex/"
        }
    ],
    "require": {
        "php": ">=7.4",
        "psr/log": "^1.0",
        "psr/container": "^2.0",
        "psr/simple-cache": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "FLEA\\": "FLEA/FLEA/"
        },
        "files": [
            "FLEA/Functions.php",
            "FLEA/FLEA.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "FLEA\\Tests\\": "tests/"
        }
    }
}
